# OpenAI API Key
OPENAI_API_KEY=sk-sua-chave-aqui

# ============================================
# OTIMIZAÇÃO PARA AWS
# ============================================

# Modelo LLM (default: gpt-3.5-turbo - mais barato)
# Opções:
#   - gpt-3.5-turbo    → $0.50/$1.50 por 1M tokens ✅ MELHOR CUSTO
#   - gpt-4o-mini      → $0.15/$0.60 por 1M tokens (melhor qualidade)
#   - gpt-4-turbo      → $10/$30 por 1M tokens (caro)
LANGCHAIN_MODEL=gpt-3.5-turbo

# Ativar busca local (RAG sem embeddings caros)
# true  = Ativar busca textual local ✅ SEM CUSTO
# false = Apenas histórico e contexto
USE_RAG=true
